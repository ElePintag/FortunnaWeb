# ============================================================================
# NUEVAS VARIABLES DE ENTORNO - SUPABASE
# ============================================================================
#
# Después de crear tu nuevo proyecto en Supabase:
# 1. Ve a: Settings → API en tu dashboard de Supabase
# 2. Copia los valores de "Project URL" y "anon public" key
# 3. Reemplaza los valores de AQUÍ ABAJO
# 4. Renombra este archivo a ".env" (o copia estos valores a tu .env existente)
#
# ============================================================================

# URL de tu nuevo proyecto de Supabase
# Ejemplo: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://TU_NUEVO_PROYECTO.supabase.co

# Anon Key de tu nuevo proyecto (clave pública)
# Es una clave larga que empieza con "eyJ..."
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_NUEVA_ANON_KEY_AQUI

# ============================================================================
# IMPORTANTE:
# ============================================================================
# - NO compartas estas credenciales públicamente
# - NO las subas a GitHub (el archivo .env está en .gitignore)
# - Actualiza TAMBIÉN estas variables en Vercel/Netlify si tienes el sitio desplegado
# ============================================================================
